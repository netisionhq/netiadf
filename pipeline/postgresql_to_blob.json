{
	"name": "postgresql_to_blob",
	"properties": {
		"activities": [
			{
				"name": "ForEach_table",
				"type": "ForEach",
				"dependsOn": [],
				"userProperties": [],
				"typeProperties": {
					"items": {
						"value": "@pipeline().parameters.items",
						"type": "Expression"
					},
					"activities": [
						{
							"name": "copy_table",
							"type": "Copy",
							"dependsOn": [],
							"policy": {
								"timeout": "0.12:00:00",
								"retry": 0,
								"retryIntervalInSeconds": 30,
								"secureOutput": false,
								"secureInput": false
							},
							"userProperties": [
								{
									"name": "Source",
									"value": "@{item().source.schema}.@{item().source.table}"
								},
								{
									"name": "Destination",
									"value": "postgresdata//@{item().destination.fileName}"
								}
							],
							"typeProperties": {
								"source": {
									"type": "PostgreSqlV2Source",
									"queryTimeout": "02:00:00"
								},
								"sink": {
									"type": "ParquetSink",
									"storeSettings": {
										"type": "AzureBlobStorageWriteSettings",
										"copyBehavior": "FlattenHierarchy"
									},
									"formatSettings": {
										"type": "ParquetWriteSettings"
									}
								},
								"enableStaging": false,
								"translator": {
									"type": "TabularTranslator",
									"mappings": [
										{
											"source": {
												"name": "invoice_id",
												"type": "String",
												"physicalType": "text"
											},
											"sink": {
												"name": "invoice_id",
												"type": "String",
												"physicalType": "UTF8"
											}
										},
										{
											"source": {
												"name": "invoice_date",
												"type": "DateTime",
												"physicalType": "timestamp without time zone"
											},
											"sink": {
												"name": "invoice_date",
												"type": "DateTime",
												"physicalType": "INT_96"
											}
										},
										{
											"source": {
												"name": "customer_id",
												"type": "Int64",
												"physicalType": "bigint"
											},
											"sink": {
												"name": "customer_id",
												"type": "Int64",
												"physicalType": "INT_64"
											}
										},
										{
											"source": {
												"name": "category",
												"type": "Int64",
												"physicalType": "bigint"
											},
											"sink": {
												"name": "category",
												"type": "Int64",
												"physicalType": "INT_64"
											}
										},
										{
											"source": {
												"name": "price",
												"type": "Double",
												"physicalType": "double precision"
											},
											"sink": {
												"name": "price",
												"type": "Double",
												"physicalType": "DOUBLE"
											}
										},
										{
											"source": {
												"name": "store_id",
												"type": "Int64",
												"physicalType": "bigint"
											},
											"sink": {
												"name": "store_id",
												"type": "Int64",
												"physicalType": "INT_64"
											}
										},
										{
											"source": {
												"name": "sku_id",
												"type": "Int64",
												"physicalType": "bigint"
											},
											"sink": {
												"name": "sku_id",
												"type": "Int64",
												"physicalType": "INT_64"
											}
										},
										{
											"source": {
												"name": "churn",
												"type": "Double",
												"physicalType": "double precision"
											},
											"sink": {
												"name": "churn",
												"type": "Double",
												"physicalType": "DOUBLE"
											}
										},
										{
											"source": {
												"name": "cust_cat_id",
												"type": "String",
												"physicalType": "text"
											},
											"sink": {
												"name": "cust_cat_id",
												"type": "String",
												"physicalType": "UTF8"
											}
										}
									],
									"typeConversion": true,
									"typeConversionSettings": {
										"allowDataTruncation": true,
										"treatBooleanAsNumber": false
									}
								}
							},
							"inputs": [
								{
									"referenceName": "PostgreSqlTable1",
									"type": "DatasetReference",
									"parameters": {
										"p_schema": "@item().source.schema",
										"p_table": "@item().source.table"
									}
								}
							],
							"outputs": [
								{
									"referenceName": "postgre_customer",
									"type": "DatasetReference",
									"parameters": {
										"p_fileName": "@item().destination.fileName"
									}
								}
							]
						}
					]
				}
			}
		],
		"parameters": {
			"items": {
				"type": "array",
				"defaultValue": [
					{
						"source": {
							"schema": "crm",
							"table": "category"
						},
						"destination": {
							"fileName": "crm.category.csv"
						}
					}
				]
			}
		},
		"annotations": []
	}
}