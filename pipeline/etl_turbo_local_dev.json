					{
						"activity": "get_blob_file_list",
						"dependencyConditions": [
							"Succeeded"
						]
					}
				],
				"userProperties": [],
				"typeProperties": {
					"items": {
						"value": "@activity('get_blob_file_list').output.childItems",
						"type": "Expression"
					},
					"condition": {
						"value": "@contains(item().name,pipeline().parameters.filetype)",
						"type": "Expression"
					}
				}
			},
			{
				"name": "loop_all_turbo_files",
				"type": "ForEach",
