									"company_id": {
										"value": {
											"value": "@pipeline().parameters.company",
											"type": "Expression"
										},
										"type": "Int64"
									},
									"log_id": {
										"value": "@variables('v_log_id')",
										"type": "Int64"
									},
									"sheet_name": {
										"value": null,
										"type": "String"
									},
									"source_file": {
										"value": "@variables('v_file_name')",
										"type": "String"
									},
									"uploaded_by": {
										"value": null,
										"type": "String"
									}
								}
							},
							"linkedServiceName": {
								"referenceName": "suraj_local_sqlsrvr",
								"type": "LinkedServiceReference"
							}
						},
						{
							"name": "get_file_name",
							"type": "SetVariable",
