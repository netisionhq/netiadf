								{
									"activity": "get_file_name",
									"dependencyConditions": [
										"Succeeded"
									]
								}
							],
							"policy": {
								"timeout": "0.12:00:00",
								"retry": 0,
								"retryIntervalInSeconds": 30,
								"secureOutput": false,
								"secureInput": false
							},
							"userProperties": [],
							"typeProperties": {
								"storedProcedureName": "audit.sp_log_batch_start",
								"storedProcedureParameters": {
									"business_unit_id": {
										"value": {
											"value": "@pipeline().parameters.business_unit",
											"type": "Expression"
										},
										"type": "Int64"
