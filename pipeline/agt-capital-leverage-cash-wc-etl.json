							"name": "extract_batch_id",
							"type": "Lookup",
							"dependsOn": [
								{
									"activity": "init_batch",
									"dependencyConditions": [
										"Succeeded"
									]
								}
							],
							"policy": {
								"timeout": "0.12:00:00",
								"retry": 0,
								"retryIntervalInSeconds": 30,
								"secureOutput": false,
								"secureInput": false
							},
							"userProperties": [],
							"typeProperties": {
								"source": {
									"type": "SqlServerSource",
									"sqlReaderQuery": {
										"value": "@concat(\n'SELECT MAX(batch_id) AS batch_id\nFROM audit.log_batch_ingestion\nWHERE log_id = ', variables('v_log_id'),\n' AND source_file = ''', variables('v_file_name'), ''''\n)",
										"type": "Expression"
									},
									"queryTimeout": "02:00:00",
									"partitionOption": "None"
								},
								"dataset": {
									"referenceName": "suraj_local_sqlDS_v1",
									"type": "DatasetReference",
									"parameters": {
										"p_table_name": "audit.log_batch_ingestion"
									}
								}
							}
						},
						{
							"name": "clean_refine_stg_table",
							"type": "Script",
							"dependsOn": [
								{
									"activity": "load_turbo_data_stg",
									"dependencyConditions": [
										"Succeeded"
									]
								}
							],
							"policy": {
								"timeout": "0.12:00:00",
								"retry": 0,
								"retryIntervalInSeconds": 30,
								"secureOutput": false,
								"secureInput": false
							},
							"userProperties": [],
							"linkedServiceName": {
								"referenceName": "suraj_local_sqlsrvr",
								"type": "LinkedServiceReference"
							},
							"typeProperties": {
								"scripts": [
									{
										"type": "Query",
										"text": "UPDATE stg.stg_workingcapital\nSET\n    measure_value      = CAST(ROUND(ISNULL(TRY_CONVERT(DECIMAL(38,12), measure_value),0),6) AS VARCHAR(50));\n\nUPDATE stg.stg_turbo_data\nSET\n    measure_value        = CASE WHEN ABS(TRY_CONVERT(FLOAT,measure_value))        < 1E-8 THEN '0' ELSE measure_value END;"
									}
								],
								"scriptBlockExecutionTimeout": "02:00:00"
							}
						},
						{
							"name": "run_validation",
							"type": "Script",
							"dependsOn": [
								{
									"activity": "clean_refine_stg_table",
									"dependencyConditions": [
										"Succeeded"
									]
								}
							],
							"policy": {
								"timeout": "0.12:00:00",
								"retry": 0,
								"retryIntervalInSeconds": 30,
								"secureOutput": false,
								"secureInput": false
							},
							"userProperties": [],
							"linkedServiceName": {
								"referenceName": "suraj_local_sqlsrvr",
								"type": "LinkedServiceReference"
							},
							"typeProperties": {
								"scripts": [
									{
										"type": "Query",
										"text": {
											"value": "EXEC audit.sp_run_validations\n     @batch_id = @{variables('v_batch_id')},\n     @table_name = 'stg.stg_workingcapital';",
											"type": "Expression"
										}
									}
								],
								"scriptBlockExecutionTimeout": "02:00:00"
							}
						},
