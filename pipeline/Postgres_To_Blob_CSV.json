						}
					},
					{
						"source": {
							"schema": "crm",
							"table": "vw_customer_shopping_data"
						},
						"destination": {
							"fileName": "crm.vw_customer_shopping_data.csv"
						}
					},
					{
						"source": {
							"schema": "public",
							"table": "billing_data"
						},
						"destination": {
							"fileName": "public.billing_data.csv"
						}
					},
					{
						"source": {
							"schema": "public",
							"table": "cfg_category"
						},
						"destination": {
							"fileName": "public.cfg_category.csv"
						}
					},
					{
						"source": {
							"schema": "public",
							"table": "cfg_sku"
						},
						"destination": {
							"fileName": "public.cfg_sku.csv"
						}
					},
					{
						"source": {
							"schema": "public",
							"table": "cfg_store"
						},
						"destination": {
							"fileName": "public.cfg_store.csv"
						}
					},
					{
						"source": {
