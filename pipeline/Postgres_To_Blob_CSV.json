					{
						"source": {
							"schema": "crm",
							"table": "rfm_table_old"
						},
						"destination": {
							"fileName": "crm.rfm_table_old.csv"
						}
					},
					{
						"source": {
							"schema": "crm",
							"table": "sku"
						},
						"destination": {
							"fileName": "crm.sku.csv"
						}
					},
					{
						"source": {
							"schema": "crm",
							"table": "store"
						},
						"destination": {
