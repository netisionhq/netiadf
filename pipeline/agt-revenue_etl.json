						"type": "Expression"
					}
				}
			},
			{
				"name": "set_v_pipeline_name",
				"type": "SetVariable",
				"dependsOn": [
					{
						"activity": "set_v_domain",
						"dependencyConditions": [
							"Succeeded"
						]
