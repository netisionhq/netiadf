				"type": "SetVariable",
				"dependsOn": [
					{
						"activity": "init_log_etl",
						"dependencyConditions": [
							"Succeeded"
						]
					}
				],
				"policy": {
					"secureOutput": false,
					"secureInput": false
				},
				"userProperties": [],
				"typeProperties": {
					"variableName": "v_log_id",
					"value": {
						"value": "@string(activity('init_log_etl').output.resultSets[0].rows[0].LogID)",
						"type": "Expression"
					}
				}
			},
			{
				"name": "get_blob_list",
				"type": "GetMetadata",
				"dependsOn": [
					{
						"activity": "set_v_log_id",
						"dependencyConditions": [
							"Succeeded"
						]
					}
				],
