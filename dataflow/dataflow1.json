{
	"name": "dataflow1",
	"properties": {
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "DelimitedText3",
						"type": "DatasetReference"
					},
					"name": "source1"
				},
				{
					"dataset": {
						"referenceName": "DelimitedText5",
						"type": "DatasetReference"
					},
					"name": "source2"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "DelimitedText6",
						"type": "DatasetReference"
					},
					"name": "sink1",
					"rejectedDataLinkedService": {
						"referenceName": "netiadfblobLS",
						"type": "LinkedServiceReference"
					}
				},
				{
					"dataset": {
						"referenceName": "DelimitedText7",
						"type": "DatasetReference"
					},
					"name": "sink2",
					"rejectedDataLinkedService": {
						"referenceName": "netiadfblobLS",
						"type": "LinkedServiceReference"
					}
				}
			],
			"transformations": [
				{
					"name": "join1"
				},
				{
					"name": "AddMatchPercent"
				},
				{
					"name": "derivedColumn1"
				},
				{
					"name": "SplitByScore"
				}
			],
			"scriptLines": [
				"source(output(",
				"          CustomerID as string,",
				"          CustomerName as string,",
				"          DateOfBirth as date,",
				"          City as string,",
				"          AccountType as string,",
				"          PAN as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> source1",
				"source(output(",
				"          CustomerID as string,",
				"          CustomerName as string,",
				"          DateOfBirth as date,",
				"          City as string,",
				"          AccountType as string,",
				"          PAN as string,",
				"          CreditScore as short,",
				"          AnnualIncomeLakh as double,",
				"          KYCStatus as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> source2",
				"source1, source2 join(source1@CustomerName == source2@CustomerName,",
				"     joinType:'inner',",
				"     matchType:'exact',",
				"     ignoreSpaces: false,",
				"     broadcast: 'auto')~> join1",
				"source1, source2 join(fuzzyCompare(source1@CustomerName, source2@CustomerName, 90.00),",
				"     joinType:'inner',",
				"     matchType:'fuzzy',",
				"     ignoreSpaces: false,",
				"     scoreColumn:'match_score',",
				"     broadcast: 'off')~> AddMatchPercent",
				"AddMatchPercent derive(match_percentage = match_score) ~> derivedColumn1",
				"derivedColumn1 split(match_score >= 91,",
				"     disjoint: false) ~> SplitByScore@(ValidMatches, InvalidMatches)",
				"SplitByScore@ValidMatches sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> sink1",
				"SplitByScore@InvalidMatches sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> sink2"
			]
		}
	}
}