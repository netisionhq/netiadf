{
	"name": "dataflow2",
	"properties": {
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "acuvon_excel",
						"type": "DatasetReference"
					},
					"name": "source1"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "clean_excel_files",
						"type": "DatasetReference"
					},
					"name": "sink1"
				}
			],
			"transformations": [
				{
					"name": "select1"
				}
			],
			"scriptLines": [
				"source(output(",
				"          Month as string,",
				"          Qtr as string,",
				"          Year as string,",
				"          Date as string,",
				"          Code as string,",
				"          Desc as string,",
				"          Channel as string,",
				"          Region as string,",
				"          {Sales Qty} as string,",
				"          {Gross Sales} as string,",
				"          {Normal Discount} as string,",
				"          Brand as string,",
				"          Category as string,",
				"          {Sub Category} as string,",
				"          {Channel Group} as string,",
				"          {Sales Category} as string,",
				"          Factory as string,",
				"          {Brand Group} as string,",
				"          {Qty Ton} as string,",
				"          {Gross Rebates} as string,",
				"          {Net Rebates} as string,",
				"          {Total Rebates} as string,",
				"          {Total Discount} as string,",
				"          {Provision Sales Return} as string,",
				"          FOC as string,",
				"          NSV as string,",
				"          RM as string,",
				"          PK as string,",
				"          {Other RM} as string,",
				"          Other as string,",
				"          Material as string,",
				"          {COGS Prod} as string,",
				"          DL as string,",
				"          MOH as string,",
				"          SC as string,",
				"          {MOH Total} as string,",
				"          GP as string,",
				"          Sales as string,",
				"          Distribution as string,",
				"          {G&A} as string,",
				"          {HO Allocation} as string,",
				"          {R&D} as string,",
				"          Export as string,",
				"          {A&P} as string,",
				"          {Sales Promotion} as string,",
				"          {Deferred Tax} as string,",
				"          {Income Tax} as string,",
				"          Interest as string,",
				"          Provision as string,",
				"          {Other Gain} as string,",
				"          {Sales Bouns} as string,",
				"          {G&A Bouns} as string,",
				"          {R&D Bonus} as string,",
				"          {Export Bonus} as string,",
				"          {Distribution Bouns} as string,",
				"          {DL Bouns} as string,",
				"          {SC Bouns} as string,",
				"          {Market/IC} as string,",
				"          {YTD/YTG} as string,",
				"          Type as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> source1",
				"source1 select(mapColumn(",
				"          each(match(/* All input columns */ true()),",
				"               trim($$) = $$)",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select1",
				"source1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> sink1"
			]
		}
	}
}